---
import Base from '~/layouts/Base.astro';
import { url } from '~/lib/url';

const faqs = [
  {
    q: 'Where do you ship?',
    a: 'Across India only — we ship from Srinivasapur (Karnataka) via verified cold-chain courier partners.',
  },
  {
    q: 'How fresh will the mangoes be when they arrive?',
    a: 'We pick and pack within 24 hours of your order. Most metros receive their box in 24–48 hours; smaller cities in 2–3 days. Mangoes ripen further on your kitchen counter.',
  },
  {
    q: 'What if a mango arrives bruised or damaged?',
    a: "Write to us within 48 hours at freshmangoes.in@gmail.com with a photo. We'll replace the affected fruit or refund — whichever you prefer.",
  },
  {
    q: 'How much does shipping cost?',
    a: 'Standard delivery is ₹99 (free on orders over ₹1,500). Express delivery is ₹199 for select metros.',
  },
  {
    q: 'Do you accept returns?',
    a: 'Mangoes are perishable, so we don\'t accept returns — but our loved-it guarantee means if you\'re unhappy, we make it right.',
  },
  {
    q: 'When does the season run?',
    a: 'Most varieties are available from April through July. Sign up for the newsletter to know when each variety is in peak.',
  },
  {
    q: 'Is there a discount code for first orders?',
    a: 'Yes — use FRESH10 at checkout for 10% off your first order.',
  },
];
---
<Base title="FAQ — FreshMangos" description="Shipping, freshness, returns and more. Everything you need to know before ordering FreshMangos.">
  <section class="container-x py-16 max-w-3xl">
    <p class="eyebrow mb-3">Help &amp; info</p>
    <h1 class="display text-5xl md:text-6xl">Good questions.</h1>
    <p class="mt-4 text-lg opacity-80">Can't find what you're looking for? <a href={url('/contact')} class="underline underline-offset-4 hover:text-[color:var(--color-saffron-600)]">Drop us a line</a>.</p>

    <div class="mt-12 divide-y divide-black/10 border-y border-black/10">
      {faqs.map(({ q, a }) => (
        <details class="group py-5">
          <summary class="cursor-pointer list-none flex items-start justify-between gap-4">
            <span class="display text-xl md:text-2xl pr-4">{q}</span>
            <span class="text-2xl mt-1 transition-transform group-open:rotate-45 text-[color:var(--color-saffron-600)]" aria-hidden="true">+</span>
          </summary>
          <p class="mt-3 text-base opacity-80 leading-relaxed">{a}</p>
        </details>
      ))}
    </div>
  </section>
</Base>
