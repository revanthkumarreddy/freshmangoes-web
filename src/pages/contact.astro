---
import Base from '~/layouts/Base.astro';
---
<Base title="Contact us — FreshMangoes" description="Get in touch with the FreshMangoes team — questions, bulk orders, partnerships welcome.">
  <section class="container-x py-16 max-w-2xl">
    <p class="eyebrow mb-3">Hello</p>
    <h1 class="display text-5xl md:text-6xl">Say hi.</h1>
    <p class="mt-4 text-lg opacity-80">
      Questions about a box, a bulk order, or just to say a mango made you smile — we'd love to hear it.
    </p>

    <div class="mt-12 grid gap-6">
      <a href="mailto:freshmangoes.in@gmail.com" class="rounded-2xl bg-white border border-black/5 shadow-sm p-6 hover:shadow-md transition-shadow">
        <div class="text-2xl mb-2" aria-hidden="true">✉️</div>
        <p class="display text-2xl">Email us</p>
        <p class="text-sm opacity-70 mt-1">freshmangoes.in@gmail.com</p>
        <p class="text-xs opacity-60 mt-1">We reply within one working day.</p>
      </a>
      <a href="https://wa.me/919844763416" class="rounded-2xl bg-white border border-black/5 shadow-sm p-6 hover:shadow-md transition-shadow">
        <div class="text-2xl mb-2" aria-hidden="true">💬</div>
        <p class="display text-2xl">WhatsApp / Call</p>
        <p class="text-sm opacity-70 mt-1">+91 9844763416</p>
        <p class="text-xs opacity-60 mt-1">Tap to chat or call our official helpline.</p>
      </a>
      <div class="rounded-2xl bg-white border border-black/5 shadow-sm p-6">
        <div class="text-2xl mb-2" aria-hidden="true">📍</div>
        <p class="display text-2xl">Our orchard</p>
        <p class="text-sm opacity-70 mt-1">Srinivasapur, Kolar district - 563138, Karnataka — India</p>
        <p class="text-xs opacity-60 mt-1">Visits welcome by appointment during harvest season.</p>
      </div>
    </div>
  </section>
</Base>
