---
import Base from '~/layouts/Base.astro';
import AddToCart from '~/components/AddToCart';
import {
  fetchAllProducts,
  fetchProductBySlug,
  primaryImage,
  galleryImages,
  priceOf,
  variantsOf,
} from '~/lib/catalog';

export async function getStaticPaths() {
  const products = await fetchAllProducts();
  return products
    .filter((p): p is typeof p & { slug: string } => !!p.slug)
    .map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = await fetchProductBySlug(slug!);
if (!product) return Astro.redirect('/shop');

const gallery = galleryImages(product);
const mainImage = primaryImage(product);
const variants = variantsOf(product);
const { price } = priceOf(product);

const descHtml: string = (product as any).description || '';
const descText = descHtml.replace(/<[^>]+>/g, '').trim();

const jsonLd = {
  '@context': 'https://schema.org/',
  '@type': 'Product',
  name: product.name,
  image: gallery,
  description: descText,
  brand: { '@type': 'Brand', name: 'FreshMangos' },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'INR',
    price: price.toString(),
    availability: 'https://schema.org/InStock',
    url: Astro.url.toString(),
  },
};
---
<Base
  title={`${product.name} — FreshMangos`}
  description={(descText || `Premium ${product.name} mangoes from our Srinivasapur orchard.`).slice(0, 160)}
  image={mainImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <nav class="container-x pt-6 text-xs opacity-70">
    <a href="/" class="hover:opacity-100">Home</a> ·
    <a href="/shop" class="hover:opacity-100"> Shop</a> ·
    <span class="opacity-90"> {product.name}</span>
  </nav>

  <section class="container-x py-10 grid lg:grid-cols-[1.1fr_1fr] gap-10 lg:gap-16 items-start">
    <div>
      <div class="aspect-[4/5] rounded-3xl overflow-hidden bg-[color:var(--color-saffron-100)] shadow-lg">
        <img src={mainImage} alt={product.name ?? ''} class="w-full h-full object-cover" />
      </div>
      {gallery.length > 1 && (
        <div class="mt-3 grid grid-cols-5 gap-2">
          {gallery.slice(0, 5).map(g => (
            <div class="aspect-square rounded-xl overflow-hidden bg-[color:var(--color-saffron-100)]">
              <img src={g} alt="" class="w-full h-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="lg:sticky lg:top-24">
      <p class="eyebrow mb-3">FreshMangos · Hand-picked</p>
      <h1 class="display text-4xl md:text-5xl tracking-tight leading-[1.05]">{product.name}</h1>
      {descText && (
        <p class="mt-4 text-base opacity-80 leading-relaxed max-w-prose">{descText.slice(0, 220)}</p>
      )}

      <div class="mt-8 p-6 rounded-2xl bg-white border border-black/5 shadow-sm">
        <AddToCart client:load productId={product._id!} productName={product.name ?? ''} variants={variants} />
      </div>

      <details class="mt-6 group rounded-2xl border border-black/10">
        <summary class="cursor-pointer list-none flex items-center justify-between p-5 font-medium">
          About this mango
          <span class="transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
        </summary>
        <div class="px-5 pb-5 text-sm opacity-80 leading-relaxed" set:html={descHtml} />
      </details>

      <details class="mt-3 group rounded-2xl border border-black/10">
        <summary class="cursor-pointer list-none flex items-center justify-between p-5 font-medium">
          Shipping &amp; freshness
          <span class="transition-transform group-open:rotate-180" aria-hidden="true">▾</span>
        </summary>
        <div class="px-5 pb-5 text-sm opacity-80 leading-relaxed space-y-2">
          <p>Picked, weighed and packed within 24 hours of your order.</p>
          <p>Standard delivery ₹99 · Free over ₹1,500 · Express ₹199.</p>
          <p>If a single mango arrives bruised, write to us — we'll make it right.</p>
        </div>
      </details>
    </div>
  </section>
</Base>
