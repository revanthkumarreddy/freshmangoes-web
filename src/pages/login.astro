---
import Base from '~/layouts/Base.astro';
import { url } from '~/lib/url';
---
<Base title="Log in — FreshMangos" noindex>
  <section class="login-page">
    <div class="login-card-centered">

      <!-- Icon -->
      <div class="login-icon-wrap">
        <div class="login-icon" id="login-icon">🥭</div>
      </div>

      <!-- Tab Switcher -->
      <div class="auth-tabs" id="auth-tabs">
        <button class="auth-tab auth-tab-active" data-tab="signin" id="tab-signin">Sign In</button>
        <button class="auth-tab" data-tab="signup" id="tab-signup">Create Account</button>
      </div>

      <!-- Sign In Form -->
      <form id="signin-form" class="auth-form">
        <div class="form-field">
          <label for="signin-email" class="form-label">Email address</label>
          <input type="email" id="signin-email" class="form-input" placeholder="you@example.com" required autocomplete="email" />
        </div>
        <div class="form-field">
          <label for="signin-password" class="form-label">Password</label>
          <div class="password-wrap">
            <input type="password" id="signin-password" class="form-input" placeholder="Enter your password" required autocomplete="current-password" />
            <button type="button" class="pw-toggle" data-target="signin-password" aria-label="Show/hide password">👁</button>
          </div>
        </div>
        <button type="submit" id="signin-submit" class="btn btn-saffron login-cta-btn">
          Sign in to your account
        </button>
        <p id="signin-error" class="form-error hidden"></p>
      </form>

      <!-- Sign Up Form -->
      <form id="signup-form" class="auth-form hidden">
        <div class="form-field">
          <label for="signup-name" class="form-label">Full name</label>
          <input type="text" id="signup-name" class="form-input" placeholder="Your full name" required autocomplete="name" />
        </div>
        <div class="form-field">
          <label for="signup-email" class="form-label">Email address</label>
          <input type="email" id="signup-email" class="form-input" placeholder="you@example.com" required autocomplete="email" />
        </div>
        <div class="form-field">
          <label for="signup-phone" class="form-label">Phone (optional)</label>
          <input type="tel" id="signup-phone" class="form-input" placeholder="+91 98765 43210" autocomplete="tel" />
        </div>
        <div class="form-field">
          <label for="signup-password" class="form-label">Password</label>
          <div class="password-wrap">
            <input type="password" id="signup-password" class="form-input" placeholder="Create a password (min 8 chars)" required autocomplete="new-password" minlength="8" />
            <button type="button" class="pw-toggle" data-target="signup-password" aria-label="Show/hide password">👁</button>
          </div>
        </div>
        <div class="form-field">
          <label for="signup-confirm" class="form-label">Confirm password</label>
          <div class="password-wrap">
            <input type="password" id="signup-confirm" class="form-input" placeholder="Re-enter your password" required autocomplete="new-password" />
            <button type="button" class="pw-toggle" data-target="signup-confirm" aria-label="Show/hide password">👁</button>
          </div>
        </div>
        <button type="submit" id="signup-submit" class="btn btn-saffron login-cta-btn">
          Create my account
        </button>
        <p id="signup-error" class="form-error hidden"></p>
      </form>

      <!-- Success State -->
      <div id="state-success" class="hidden" style="text-align:center;">
        <div style="font-size:3rem;margin-bottom:0.75rem;">🎉</div>
        <h2 class="display" style="font-size:1.5rem;color:var(--color-leaf-600);margin-bottom:0.5rem;">Welcome!</h2>
        <p style="font-size:0.85rem;opacity:0.7;">Redirecting to your account…</p>
        <div class="spinner-wrap" style="margin-top:1rem;">
          <span class="spinner"></span>
        </div>
      </div>

      <!-- Divider -->
      <div class="auth-divider" id="auth-divider">
        <span>or</span>
      </div>

      <!-- Google Sign-In via Wix OAuth -->
      <button id="wix-login-btn" class="btn btn-wix-login" type="button">
        <svg width="18" height="18" viewBox="0 0 24 24">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google (via Wix)
      </button>

      <p class="login-hint" id="login-hint">
        Your data is stored securely on your device. We never share your information.
      </p>

      <div class="login-footer">
        <a href={url('/')} class="login-back-link">← Back to store</a>
      </div>
    </div>
  </section>

  <script>
    import { wixClient, isLoggedIn } from '~/lib/wix-client';

    document.addEventListener('DOMContentLoaded', () => {
      const BASE = (import.meta.env.BASE_URL || '/').replace(/\/$/, '');

      // Elements
      const tabSignIn    = document.getElementById('tab-signin');
      const tabSignUp    = document.getElementById('tab-signup');
      const signinForm   = document.getElementById('signin-form') as HTMLFormElement | null;
      const signupForm   = document.getElementById('signup-form') as HTMLFormElement | null;
      const successEl    = document.getElementById('state-success');
      const authTabs     = document.getElementById('auth-tabs');
      const authDivider  = document.getElementById('auth-divider');
      const wixLoginBtn  = document.getElementById('wix-login-btn');
      const loginHint    = document.getElementById('login-hint');
      const loginIcon    = document.getElementById('login-icon');
      const signinError  = document.getElementById('signin-error');
      const signupError  = document.getElementById('signup-error');

      // If already logged in (via Wix OR local), redirect to account
      if (isLoggedIn() || localStorage.getItem('fm:user')) {
        showSuccess();
        return;
      }

      // Tab switching
      tabSignIn?.addEventListener('click', () => switchTab('signin'));
      tabSignUp?.addEventListener('click', () => switchTab('signup'));

      function switchTab(tab: 'signin' | 'signup') {
        tabSignIn?.classList.toggle('auth-tab-active', tab === 'signin');
        tabSignUp?.classList.toggle('auth-tab-active', tab === 'signup');
        signinForm?.classList.toggle('hidden', tab !== 'signin');
        signupForm?.classList.toggle('hidden', tab !== 'signup');
        signinError?.classList.add('hidden');
        signupError?.classList.add('hidden');
      }

      // Password visibility toggle
      document.querySelectorAll('.pw-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = (btn as HTMLElement).dataset.target!;
          const input = document.getElementById(targetId) as HTMLInputElement;
          if (!input) return;
          input.type = input.type === 'password' ? 'text' : 'password';
          (btn as HTMLElement).textContent = input.type === 'password' ? '👁' : '🙈';
        });
      });

      // Hash helper using Web Crypto
      async function hashPassword(pw: string): Promise<string> {
        const enc = new TextEncoder();
        const buf = await crypto.subtle.digest('SHA-256', enc.encode(pw));
        return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
      }

      // Sign In
      signinForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email    = (document.getElementById('signin-email')    as HTMLInputElement)?.value?.trim();
        const password = (document.getElementById('signin-password') as HTMLInputElement)?.value;
        if (!email || !password) return;

        const users = getLocalUsers();
        const user  = users.find((u: any) => u.email.toLowerCase() === email.toLowerCase());

        if (!user) {
          if (signinError) {
            signinError.textContent = 'No account found with this email. Please create an account first.';
            signinError.classList.remove('hidden');
          }
          setTimeout(() => {
            switchTab('signup');
            const signupEmail = document.getElementById('signup-email') as HTMLInputElement;
            if (signupEmail) signupEmail.value = email;
          }, 1500);
          return;
        }

        // Verify password
        const hash = await hashPassword(password);
        if (user.passwordHash && user.passwordHash !== hash) {
          if (signinError) {
            signinError.textContent = 'Incorrect password. Please try again.';
            signinError.classList.remove('hidden');
          }
          return;
        }

        localStorage.setItem('fm:user', JSON.stringify({ ...user, lastLogin: new Date().toISOString() }));
        localStorage.setItem('wix:member_name', user.name);
        window.dispatchEvent(new Event('auth:updated'));
        showSuccess();
      });

      // Sign Up
      signupForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name     = (document.getElementById('signup-name')     as HTMLInputElement)?.value?.trim();
        const email    = (document.getElementById('signup-email')    as HTMLInputElement)?.value?.trim();
        const phone    = (document.getElementById('signup-phone')    as HTMLInputElement)?.value?.trim();
        const password = (document.getElementById('signup-password') as HTMLInputElement)?.value;
        const confirm  = (document.getElementById('signup-confirm')  as HTMLInputElement)?.value;

        if (!name || !email || !password) return;

        if (password.length < 8) {
          if (signupError) {
            signupError.textContent = 'Password must be at least 8 characters.';
            signupError.classList.remove('hidden');
          }
          return;
        }

        if (password !== confirm) {
          if (signupError) {
            signupError.textContent = 'Passwords do not match. Please try again.';
            signupError.classList.remove('hidden');
          }
          return;
        }

        const users = getLocalUsers();
        if (users.find((u: any) => u.email.toLowerCase() === email.toLowerCase())) {
          if (signupError) {
            signupError.textContent = 'An account with this email already exists. Please sign in instead.';
            signupError.classList.remove('hidden');
          }
          setTimeout(() => {
            switchTab('signin');
            const signinEmail = document.getElementById('signin-email') as HTMLInputElement;
            if (signinEmail) signinEmail.value = email;
          }, 1500);
          return;
        }

        const passwordHash = await hashPassword(password);
        const user = {
          id: crypto.randomUUID?.() || `user_${Date.now()}`,
          name,
          email,
          phone: phone || '',
          passwordHash,
          createdAt: new Date().toISOString(),
          lastLogin: new Date().toISOString(),
        };

        users.push(user);
        localStorage.setItem('fm:users', JSON.stringify(users));
        localStorage.setItem('fm:user', JSON.stringify(user));
        localStorage.setItem('wix:member_name', name);
        window.dispatchEvent(new Event('auth:updated'));
        showSuccess();
      });

      // Wix OAuth (Google via Wix)
      wixLoginBtn?.addEventListener('click', async () => {
        try {
          wixLoginBtn.setAttribute('disabled', 'true');
          wixLoginBtn.textContent = 'Redirecting to Google…';

          const REDIRECT_URI =
            document.querySelector('meta[name="wix-redirect-uri"]')?.getAttribute('content') ||
            `${window.location.origin}${BASE}/login-callback`;

          const returnUrl = new URL(`${BASE}/account`, window.location.origin).href;
          const oauthData = wixClient.auth.generateOAuthData(REDIRECT_URI, returnUrl);
          sessionStorage.setItem('wix:oauthData', JSON.stringify(oauthData));

          const { authUrl } = await wixClient.auth.getAuthUrl(oauthData);
          window.location.href = authUrl;
        } catch (err: any) {
          console.error('[FreshMangos] Wix OAuth error:', err);
          wixLoginBtn.removeAttribute('disabled');
          wixLoginBtn.innerHTML = `
            <svg width="18" height="18" viewBox="0 0 24 24">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            Continue with Google (via Wix)
          `;
          // Show helpful error
          alert('Google login via Wix requires additional configuration in your Wix dashboard. Please use email sign-in for now, or configure the OAuth redirect URI in Wix Developer Console.');
        }
      });

      function showSuccess() {
        signinForm?.classList.add('hidden');
        signupForm?.classList.add('hidden');
        authTabs?.classList.add('hidden');
        authDivider?.classList.add('hidden');
        wixLoginBtn?.classList.add('hidden');
        loginHint?.classList.add('hidden');
        successEl?.classList.remove('hidden');
        if (loginIcon) loginIcon.textContent = '✅';

        setTimeout(() => {
          window.location.replace(`${BASE}/account`);
        }, 1000);
      }

      function getLocalUsers(): any[] {
        try {
          return JSON.parse(localStorage.getItem('fm:users') || '[]');
        } catch {
          return [];
        }
      }

      console.log('[FreshMangos] Login page initialized');
    });
  </script>

  <style>
    .login-page {
      min-height: calc(100vh - 68px);
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--color-cream) 0%, var(--color-saffron-50) 40%, var(--color-saffron-100) 100%);
      padding: 2rem 1.25rem;
    }
    .login-card-centered {
      background: white;
      border-radius: 1.5rem;
      padding: 2.5rem 2.5rem 2rem;
      box-shadow: 0 20px 60px -15px rgba(165, 95, 0, 0.15), 0 0 0 1px rgba(0,0,0,0.04);
      max-width: 440px;
      width: 100%;
    }
    .login-icon-wrap { text-align: center; margin-bottom: 1.5rem; }
    .login-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 4.5rem;
      height: 4.5rem;
      border-radius: 50%;
      background: var(--color-saffron-50);
      box-shadow: 0 8px 30px -8px rgba(237, 155, 20, 0.3);
      font-size: 2.5rem;
      animation: floatIcon 3s ease-in-out infinite;
    }
    @keyframes floatIcon {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }

    /* Auth Tabs */
    .auth-tabs {
      display: flex;
      background: var(--color-saffron-50);
      border-radius: 0.75rem;
      padding: 0.25rem;
      margin-bottom: 1.5rem;
    }
    .auth-tab {
      flex: 1;
      padding: 0.6rem 1rem;
      border: none;
      background: transparent;
      border-radius: 0.55rem;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      font-family: var(--font-sans);
      color: var(--color-ink-soft);
    }
    .auth-tab-active {
      background: white;
      color: var(--color-ink);
      box-shadow: 0 2px 8px -2px rgba(0,0,0,0.1);
    }
    .auth-tab:hover:not(.auth-tab-active) {
      color: var(--color-ink);
    }

    /* Form */
    .auth-form { display: flex; flex-direction: column; gap: 1rem; }
    .form-field { text-align: left; }
    .password-wrap { position: relative; }
    .password-wrap .form-input { padding-right: 3rem; }
    .pw-toggle {
      position: absolute;
      right: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      font-size: 1rem;
      line-height: 1;
      padding: 0.25rem;
      color: var(--color-ink-soft);
      transition: opacity 0.2s;
    }
    .pw-toggle:hover { opacity: 0.7; }
    .form-label {
      display: block;
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--color-ink-soft);
      margin-bottom: 0.4rem;
      letter-spacing: 0.02em;
    }
    .form-input {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid rgba(0,0,0,0.1);
      border-radius: 0.75rem;
      font-size: 0.9rem;
      font-family: var(--font-sans);
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
      background: white;
      box-sizing: border-box;
    }
    .form-input:focus {
      border-color: var(--color-saffron-400);
      box-shadow: 0 0 0 3px rgba(237, 155, 20, 0.12);
    }
    .form-input::placeholder { color: var(--color-ink-soft); opacity: 0.4; }
    .form-error {
      font-size: 0.78rem;
      color: #dc2626;
      background: #fef2f2;
      padding: 0.6rem 0.85rem;
      border-radius: 0.5rem;
      border: 1px solid #fecaca;
      margin: 0;
    }
    .login-cta-btn {
      width: 100%;
      font-size: 0.95rem;
      padding: 0.85rem 1.5rem;
      cursor: pointer;
      margin-top: 0.25rem;
    }

    /* Divider */
    .auth-divider {
      display: flex;
      align-items: center;
      margin: 1.25rem 0;
      gap: 0.75rem;
    }
    .auth-divider::before,
    .auth-divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: rgba(0,0,0,0.08);
    }
    .auth-divider span {
      font-size: 0.75rem;
      color: var(--color-ink-soft);
      opacity: 0.5;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    /* Wix/Google login */
    .btn-wix-login {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.6rem;
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1.5px solid rgba(0,0,0,0.12);
      border-radius: 999px;
      background: white;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
      font-family: var(--font-sans);
      color: var(--color-ink);
    }
    .btn-wix-login:hover {
      background: var(--color-saffron-50);
      border-color: var(--color-saffron-300);
    }
    .btn-wix-login:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    .login-hint {
      font-size: 0.72rem;
      color: var(--color-ink-soft);
      opacity: 0.5;
      margin-top: 1.25rem;
      text-align: center;
    }
    .login-footer {
      margin-top: 1.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid rgba(0,0,0,0.06);
      text-align: center;
    }
    .login-back-link {
      font-size: 0.85rem;
      color: var(--color-ink-soft);
      text-decoration: none;
      transition: color 0.2s;
    }
    .login-back-link:hover { color: var(--color-saffron-600); }

    .spinner-wrap { display: flex; justify-content: center; }
    .spinner {
      display: inline-block;
      width: 1.5rem;
      height: 1.5rem;
      border: 3px solid var(--color-saffron-200);
      border-top-color: var(--color-saffron-600);
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .hidden { display: none !important; }
  </style>
</Base>
