---
import Base from '~/layouts/Base.astro';
---
<Base title="Thank you — FreshMangos" noindex>
  <section class="container-x py-24 text-center max-w-2xl mx-auto">
    <div class="text-6xl mb-6">🥭</div>
    <h1 class="display text-5xl md:text-6xl">Thank you!</h1>
    <p class="mt-5 text-lg opacity-80 leading-relaxed">
      Your mangoes are on their way to being picked. We'll send a confirmation email shortly with
      tracking once your box leaves the orchard.
    </p>
    <p id="order-ref" class="mt-6 text-sm opacity-70"></p>
    <div class="mt-10 flex justify-center gap-3 flex-wrap">
      <a href="/" class="btn btn-ghost">Back to home</a>
      <a href="/shop" class="btn btn-saffron">Shop more</a>
    </div>
  </section>

  <script>
    const url = new URL(window.location.href);
    const id = url.searchParams.get('orderId') || url.searchParams.get('order_id');
    if (id) {
      const el = document.getElementById('order-ref');
      if (el) el.textContent = `Order reference: ${id}`;
    }
    // Clear local cart token cache so the next visit starts fresh.
    try { window.localStorage.removeItem('wix:tokens'); } catch {}
  </script>
</Base>
