---
import { url } from '~/lib/url';
const navLinks = [
  { href: url('/'), label: 'Home' },
  { href: url('/shop'), label: 'Shop' },
  { href: url('/about'), label: 'Our Farm' },
  { href: url('/faq'), label: 'FAQ' },
  { href: url('/contact'), label: 'Contact' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-[color:var(--color-cream)]/85 border-b border-black/5">
  <div class="container-x flex items-center justify-between h-[68px]">
    <a href={url('/')} class="flex items-center gap-2 group" aria-label="FreshMangos home">
      <span class="text-2xl" aria-hidden="true">🥭</span>
      <span class="display text-2xl tracking-tight">FreshMangos</span>
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm font-medium">
      {navLinks.map(l => (
        <a
          href={l.href}
          class:list={[
            "relative py-1 transition-colors",
            path === l.href ? "text-[color:var(--color-saffron-600)]" : "hover:text-[color:var(--color-saffron-600)]"
          ]}
        >
          {l.label}
          {path === l.href && <span class="absolute -bottom-0.5 left-0 right-0 h-px bg-[color:var(--color-saffron-500)]" />}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href={url('/cart')} class="btn btn-ghost !py-2 !px-4 text-sm" aria-label="Cart">
        <span aria-hidden="true">🛒</span>
        <span class="hidden sm:inline">Cart</span>
        <span id="cart-count" class="hidden ml-1 text-xs font-bold rounded-full bg-[color:var(--color-saffron-400)] text-[color:var(--color-ink)] w-5 h-5 items-center justify-center">0</span>
      </a>
    </div>
  </div>
</header>

<script>
  import { wixClient } from '~/lib/wix-client';
  async function refresh() {
    try {
      const cart = await wixClient.currentCart.getCurrentCart();
      const count = (cart.lineItems || []).reduce((s, l) => s + (l.quantity || 0), 0);
      const el = document.getElementById('cart-count');
      if (!el) return;
      if (count > 0) {
        el.textContent = String(count);
        el.classList.remove('hidden');
        el.classList.add('inline-flex');
      } else {
        el.classList.add('hidden');
      }
    } catch { /* no cart yet */ }
  }
  refresh();
  window.addEventListener('cart:updated', refresh);
</script>
