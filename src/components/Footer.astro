---
import { url } from '~/lib/url';
const year = new Date().getFullYear();
---
<footer class="mt-24 bg-[color:var(--color-ink)] text-[color:var(--color-cream)]">
  <div class="container-x py-16 grid gap-12 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl" aria-hidden="true">🥭</span>
        <span class="display text-2xl">FreshMangos</span>
      </div>
      <p class="text-sm opacity-80 max-w-sm leading-relaxed">
        Hand-picked, sun-ripened mangoes from our family orchard in Srinivasapur, Karnataka.
        Twenty years of farming heritage in every box.
      </p>
      <p class="text-xs opacity-60 mt-6">Free shipping across India on orders over ₹1,500.</p>
    </div>

    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider opacity-70 mb-4">Shop</h4>
      <ul class="space-y-2 text-sm">
        <li><a href={url('/shop')} class="opacity-90 hover:opacity-100 hover:text-[color:var(--color-saffron-300)]">All mangoes</a></li>
        <li><a href={url('/about')} class="opacity-90 hover:opacity-100 hover:text-[color:var(--color-saffron-300)]">Our farm story</a></li>
        <li><a href={url('/faq')} class="opacity-90 hover:opacity-100 hover:text-[color:var(--color-saffron-300)]">FAQ &amp; shipping</a></li>
        <li><a href={url('/contact')} class="opacity-90 hover:opacity-100 hover:text-[color:var(--color-saffron-300)]">Get in touch</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold uppercase tracking-wider opacity-70 mb-4">Reach us</h4>
      <ul class="space-y-2 text-sm opacity-90">
        <li>Srinivasapur, Kolar district</li>
        <li>Karnataka, India</li>
        <li><a href="mailto:hello@freshmangoes.com" class="hover:text-[color:var(--color-saffron-300)]">hello@freshmangoes.com</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="container-x py-6 text-xs opacity-70 flex flex-col md:flex-row gap-2 md:justify-between">
      <span>© {year} FreshMangos. All rights reserved.</span>
      <span>Built with care · Hosted on GitHub Pages · Powered by Wix Headless</span>
    </div>
  </div>
</footer>
