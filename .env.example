# Public Wix Headless OAuth Client ID for the FreshMangos site
# (safe to commit / expose to the browser — visitor flow only, no secret)
PUBLIC_WIX_CLIENT_ID=<your-wix-oauth-client-id>

# The exact redirect URI registered in your Wix OAuth App settings (Wix Developer Console).
# For local dev:   http://localhost:4321/freshmangoes-web/login-callback
# For production:  https://<your-domain>/freshmangoes-web/login-callback
PUBLIC_WIX_REDIRECT_URI=http://localhost:4321/freshmangoes-web/login-callback
